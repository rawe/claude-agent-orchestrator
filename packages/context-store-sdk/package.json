    "test:watch": "vitest"
  },
  "keywords": [
    "context-store",
    "document-store",
    "sdk",
    "typescript"
  ],
  "author": "rawe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rawe/claude-agent-orchestrator"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "~5.6.2",
    "vitest": "^2.0.0"
  }
}
